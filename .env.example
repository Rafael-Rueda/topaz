# Application
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Redis (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Queue
QUEUE_PREFIX=topaz

# Webhook
WEBHOOK_SECRET_KEY=your-secret-key-here

# Batch Processing
BATCH_CHUNK_SIZE=500

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=docker
DB_PASSWORD=docker
DB_NAME=topaz
