generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// PHASE 1 — Write-Ahead Log (Persistence)
// ============================================

enum EventStatus {
  RECEIVED   // Saved in Postgres, awaiting enqueue
  QUEUED     // Enqueued in Redis (BullMQ)
  PROCESSING // Worker catched from queue
  DELIVERED  // Delivered to the target with success
  FAILED     // Failed in all retries
  DEAD       // DLQ — requires manual action or replay
  DISCARDED  // Manually discarded from DLQ
}

enum ValidationStatus {
  VALID
  INVALID
  NO_SCHEMA
  SKIPPED
}

model Event {
  id         String      @id @default(cuid())
  externalId String?     @map("external_id")
  source     String
  eventType  String?     @map("event_type")
  status     EventStatus @default(RECEIVED)

  payload   Json
  headers   Json
  signature String?

  // Schema validation
  validationStatus  ValidationStatus @default(SKIPPED) @map("validation_status")
  validationErrors  Json?            @map("validation_errors")

  // Processing
  attempts  Int      @default(0)
  lastError String?  @map("last_error")

  // Timestamps
  createdAt   DateTime  @default(now()) @map("created_at")
  queuedAt    DateTime? @map("queued_at")
  processedAt DateTime? @map("processed_at")
  failedAt    DateTime? @map("failed_at")

  // Relations
  deliveries Delivery[]

  @@index([source, status])
  @@index([status, createdAt])
  @@index([source, eventType, createdAt])
  @@unique([source, externalId])
  @@map("events")
}

// ============================================
// PHASE 2 — Schema Validation
// ============================================

model SchemaDefinition {
  id        String  @id @default(cuid())
  source    String
  eventType String  @map("event_type")
  version   Int     @default(1)
  schema    Json    // JSON Schema (Ajv)
  rejectOnFail Boolean @default(false) @map("reject_on_fail")
  active    Boolean @default(true)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([source, eventType, version])
  @@index([source, eventType, active])
  @@map("schema_definitions")
}

// ============================================
// PHASE 3 — Replay
// ============================================

enum ReplayStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model ReplayRequest {
  id              String       @id @default(cuid())
  filterSource    String?      @map("filter_source")
  filterEventType String?      @map("filter_event_type")
  filterStatus    EventStatus? @map("filter_status")
  filterFrom      DateTime?    @map("filter_from")
  filterTo        DateTime?    @map("filter_to")

  totalEvents    Int          @default(0) @map("total_events")
  replayedEvents Int          @default(0) @map("replayed_events")
  status         ReplayStatus @default(PENDING)
  requestedBy    String?      @map("requested_by")

  createdAt   DateTime  @default(now()) @map("created_at")
  completedAt DateTime? @map("completed_at")

  @@index([status])
  @@map("replay_requests")
}

// ============================================
// PHASE 4 — Dashboard (Alerts)
// ============================================

enum AlertMetric {
  ERROR_RATE
  QUEUE_SIZE
  LATENCY_P95
  DLQ_SIZE
  SCHEMA_DRIFT
}

model AlertRule {
  id        String      @id @default(cuid())
  name      String
  metric    AlertMetric
  threshold Float
  window    String      // e.g.: "5m", "1h"
  targetUrl String      @map("target_url") // Slack, Discord, PagerDuty
  cooldown  String      @default("5m")
  active    Boolean     @default(true)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  history AlertHistory[]

  @@map("alert_rules")
}

model AlertHistory {
  id          String   @id @default(cuid())
  alertRuleId String   @map("alert_rule_id")
  metricValue Float    @map("metric_value")
  message     String
  firedAt     DateTime @default(now()) @map("fired_at")

  alertRule AlertRule @relation(fields: [alertRuleId], references: [id], onDelete: Cascade)

  @@index([alertRuleId, firedAt])
  @@map("alert_history")
}

// ============================================
// PHASE 5 — Routing & Fan-out
// ============================================

enum RouteMethod {
  POST
  PUT
  PATCH
}

enum RoutePriority {
  CRITICAL
  HIGH
  NORMAL
  LOW
}

enum BackoffStrategy {
  FIXED
  EXPONENTIAL
}

model Route {
  id          String         @id @default(cuid())
  source      String
  eventType   String         @default("*") @map("event_type")
  targetUrl   String         @map("target_url")
  targetName  String         @map("target_name")
  method      RouteMethod    @default(POST)
  timeout     Int            @default(5000) // ms
  retryCount  Int            @default(3)    @map("retry_count")
  retryBackoff BackoffStrategy @default(EXPONENTIAL) @map("retry_backoff")
  priority    RoutePriority  @default(NORMAL)
  headers     Json?          // Custom headers
  active      Boolean        @default(true)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  deliveries Delivery[]

  @@index([source, eventType, active])
  @@map("routes")
}

enum DeliveryStatus {
  PENDING
  DELIVERED
  FAILED
}

model Delivery {
  id           String         @id @default(cuid())
  eventId      String         @map("event_id")
  routeId      String         @map("route_id")
  status       DeliveryStatus @default(PENDING)
  responseCode Int?           @map("response_code")
  responseBody String?        @map("response_body")
  durationMs   Int?           @map("duration_ms")
  attempts     Int            @default(0)
  lastError    String?        @map("last_error")

  createdAt   DateTime  @default(now()) @map("created_at")
  completedAt DateTime? @map("completed_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  route Route @relation(fields: [routeId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([routeId, status])
  @@map("deliveries")
}

// ============================================
// PHASE 6 — Transforms
// ============================================

model Transform {
  id        String  @id @default(cuid())
  source    String
  eventType String  @map("event_type")
  mapping   Json    // Declarative field mapping
  active    Boolean @default(true)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([source, eventType])
  @@map("transforms")
}

// ============================================
// PHASE 8 — Source Management
// ============================================

enum SignatureAlgorithm {
  HMAC_SHA256
  HMAC_SHA512
}

model Source {
  id                 String              @id @default(cuid())
  name               String              @unique // slug used in the URL
  signatureHeader    String?             @map("signature_header")
  signatureSecret    String?             @map("signature_secret")
  signatureAlgorithm SignatureAlgorithm? @map("signature_algorithm")
  dedupField         String?             @map("dedup_field")
  dedupWindow        String?             @map("dedup_window") // e.g.: "72h"
  rateLimitMax       Int?                @map("rate_limit_max")
  rateLimitWindow    Int?                @map("rate_limit_window") // ms
  active             Boolean             @default(true)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("sources")
}
