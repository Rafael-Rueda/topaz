# Application
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Redis (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Queue
QUEUE_PREFIX=topaz

# Webhook
WEBHOOK_SECRET_KEY=your-secret-key-here

# Batch Processing
BATCH_CHUNK_SIZE=500

# Database
DATABASE_URL=postgresql://docker:docker@localhost:5432/topaz
DB_POOL_MAX=20
DB_POOL_MIN=5
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONNECTION_TIMEOUT=5000
