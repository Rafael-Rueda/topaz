### Topaz API - Complete Test Flow
### Run requests top-to-bottom to test all features
### Base URL (default port from env.ts)
@baseUrl = http://localhost:3333


### ============================================
### 1. HEALTH — Verify services are up
### ============================================

### 1.1 Full health check (Postgres + Redis)
GET {{baseUrl}}/health

### 1.2 Readiness probe (Kubernetes)
GET {{baseUrl}}/health/ready

### 1.3 Liveness probe (Kubernetes)
GET {{baseUrl}}/health/live


### ============================================
### 2. SCHEMAS — Create validation rules FIRST
###    (so incoming webhooks get validated)
### ============================================

### 2.1 Create schema for Stripe payment events
POST {{baseUrl}}/schemas
Content-Type: application/json

{
    "source": "stripe",
    "eventType": "payment_intent.succeeded",
    "schema": {
        "type": "object",
        "required": ["type", "data"],
        "properties": {
            "type": { "type": "string" },
            "data": {
                "type": "object",
                "required": ["object"],
                "properties": {
                    "object": {
                        "type": "object",
                        "required": ["id", "amount", "currency"],
                        "properties": {
                            "id": { "type": "string" },
                            "amount": { "type": "number", "minimum": 0 },
                            "currency": { "type": "string", "minLength": 3, "maxLength": 3 }
                        }
                    }
                }
            }
        }
    },
    "rejectOnFail": false
}

### 2.2 Create strict schema for Stripe refunds (rejects invalid payloads)
POST {{baseUrl}}/schemas
Content-Type: application/json

{
    "source": "stripe",
    "eventType": "charge.refunded",
    "schema": {
        "type": "object",
        "required": ["type", "data"],
        "properties": {
            "type": { "type": "string" },
            "data": {
                "type": "object",
                "required": ["object"],
                "properties": {
                    "object": {
                        "type": "object",
                        "required": ["id", "amount_refunded"],
                        "properties": {
                            "id": { "type": "string" },
                            "amount_refunded": { "type": "number" }
                        }
                    }
                }
            }
        }
    },
    "rejectOnFail": true
}

### 2.3 List all schemas
GET {{baseUrl}}/schemas

### 2.4 List schemas by source
GET {{baseUrl}}/schemas/source/stripe

### 2.5 Get active schema for specific source + event type
GET {{baseUrl}}/schemas/source/stripe/payment_intent.succeeded


### ============================================
### 3. WEBHOOKS — Ingest events (the core flow)
###    Events: persist → buffer → Postgres → Redis queue
### ============================================

### 3.1 Stripe — valid payment (matches schema)
POST {{baseUrl}}/webhooks/stripe
Content-Type: application/json
X-Webhook-Signature: sha256=abc123

{
    "id": "evt_001",
    "type": "payment_intent.succeeded",
    "data": {
        "object": {
            "id": "pi_001",
            "amount": 9990,
            "currency": "brl",
            "status": "succeeded"
        }
    }
}

### 3.2 Stripe — another payment
POST {{baseUrl}}/webhooks/stripe
Content-Type: application/json

{
    "id": "evt_002",
    "type": "payment_intent.succeeded",
    "data": {
        "object": {
            "id": "pi_002",
            "amount": 15000,
            "currency": "usd",
            "status": "succeeded"
        }
    }
}

### 3.3 Stripe — payment with invalid schema (amount is string, not number)
### Should still accept (rejectOnFail=false) but mark as INVALID
POST {{baseUrl}}/webhooks/stripe
Content-Type: application/json

{
    "id": "evt_003",
    "type": "payment_intent.succeeded",
    "data": {
        "object": {
            "id": "pi_003",
            "amount": "not_a_number",
            "currency": "brl"
        }
    }
}

### 3.4 Stripe — refund with INVALID payload (strict mode → should be rejected 400)
POST {{baseUrl}}/webhooks/stripe
Content-Type: application/json

{
    "id": "evt_004",
    "type": "charge.refunded",
    "data": {
        "object": {
            "id": "re_001"
        }
    }
}

### 3.5 PagSeguro — no schema defined (validation=SKIPPED)
POST {{baseUrl}}/webhooks/pagseguro
Content-Type: application/json

{
    "notificationCode": "ABC123-DEF456",
    "notificationType": "transaction"
}

### 3.6 Mailchimp — subscriber event
POST {{baseUrl}}/webhooks/mailchimp
Content-Type: application/json

{
    "type": "subscribe",
    "fired_at": "2024-01-15 10:30:00",
    "data": {
        "email": "user@example.com",
        "list_id": "abc123"
    }
}

### 3.7 HubSpot — CRM contact created
POST {{baseUrl}}/webhooks/hubspot
Content-Type: application/json

[
    {
        "eventId": 1,
        "subscriptionId": 12345,
        "portalId": 67890,
        "occurredAt": 1704067200000,
        "eventType": "contact.creation",
        "objectId": 123
    }
]

### 3.8 Shopify — order created
POST {{baseUrl}}/webhooks/shopify
Content-Type: application/json

{
    "type": "orders/create",
    "data": {
        "id": "order_789",
        "total_price": "299.90",
        "currency": "BRL",
        "customer": {
            "email": "cliente@example.com"
        }
    }
}

