{
    "name": "@rueda-gems/topaz",
    "version": "1.0.0",
    "description": "High-Volatility Ingestion & Refining Unit - Stabilize the flux. Protect the Core.",
    "main": "dist/interface/http/server.js",
    "type": "module",
    "scripts": {
        "dev": "tsx watch src/interface/http/server.ts",
        "dev:worker": "tsx watch src/interface/workers/index.ts",
        "build": "tsc",
        "start": "node dist/interface/http/server.js",
        "start:worker": "node dist/interface/workers/index.js",
        "lint": "biome check --write",
        "typecheck": "tsc --noEmit",
        "prisma:generate": "npx prisma generate",
        "db:migrate": "npx prisma migrate dev",
        "db:push": "npx prisma db push",
        "db:studio": "npx prisma studio",
        "dashboard:dev": "npm --prefix dashboard run dev",
        "dashboard:build": "npm --prefix dashboard run build",
        "dashboard:serve": "npm --prefix dashboard run serve",
        "test:load": "node load-test.js",
        "test:load:quick": "node load-test-quick.js"
    },
    "keywords": [
        "boilerplate",
        "fastify",
        "bullmq",
        "ddd",
        "ingestion",
        "webhooks",
        "streaming"
    ],
    "author": "Rueda Gems",
    "license": "MIT",
    "engines": {
        "node": ">=20.0.0"
    },
    "dependencies": {
        "@fastify/cors": "^11.0.0",
        "@fastify/helmet": "^13.0.0",
        "@fastify/multipart": "^9.0.3",
        "@prisma/adapter-pg": "^7.5.0",
        "@prisma/client": "^7.5.0",
        "ajv": "^8.18.0",
        "ajv-formats": "^3.0.1",
        "awilix": "^12.0.4",
        "axios": "^1.13.6",
        "bullmq": "^5.34.8",
        "csv-parser": "^3.2.0",
        "dotenv": "^17.3.1",
        "fastify": "^5.8.2",
        "ioredis": "^5.4.2",
        "nanoid": "^5.0.9",
        "pg": "^8.20.0",
        "pino": "^9.6.0",
        "pino-pretty": "^13.0.0",
        "prisma": "^7.5.0",
        "zod": "^3.24.1"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.3.11",
        "@rueda.dev/config": "^1.6.1",
        "@types/node": "^22.10.5",
        "@types/pg": "^8.18.0",
        "@typescript-eslint/eslint-plugin": "^8.19.1",
        "@typescript-eslint/parser": "^8.19.1",
        "tsx": "^4.19.2",
        "typescript": "^5.7.3"
    }
}
